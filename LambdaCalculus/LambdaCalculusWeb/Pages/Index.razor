@page "/"
@using System.Text.Json
@using System.IO
@inject NavigationManager Nav
@inject IJSRuntime JS

<style>
a {
    color: pink;
}
.neat {
    padding: 10px;
    border: 1px solid gray;
    border-radius: 6px;
    font-size: 14pt;
    font-family: "Overpass Mono";
    background: 0;
    color: #fafafa;
}
p {
    font-size: 16pt;
}
h3 {
    font-size: 18pt;
}
h1 {
    font-size: 20pt;
}
.submit-button:active {
    background-color: #2F2F2F;
}
.submit-button {
    cursor: pointer;
    padding-left: 10px;
    padding-right: 10px;
}

@@media (min-width: 768px) {
    body {
        width: 768px;
    }
}

@@media (min-width: 992px) {
    body {
        width: 940px;
    }
}

@@media (min-width: 1200px) {
    body {
        width: 1140px;
    }
}


body {
    margin-top: 50px;
    margin-right: auto;
    margin-left: auto;
    font-family: "Overpass Mono";
    background: #1F1F1F;
    color: #fafafa;
}
.segment {
    padding: 30px;
    border: 1px solid lightgray;
    border-radius: 6px;
}
.result {
    padding: 7px;
    border: 1px solid white;
    background: darkviolet;
    border-radius: 6px;
}
.qr-section {
    padding: 30px;
    border: 1px solid lightgray;
    border-radius: 6px;
    text-align: center;
    margin-top: 50px;
}
.qr-code {
    margin-top: 20px;
}
.qr-code img {
    max-width: 200px;
    height: auto;
}
</style>

<link rel="stylesheet" type="text/css" href="https://fonts.googleapis.com/css?family=Overpass+Mono">

<h1>λ calculus calculator</h1>

<p>
    Welcome to lambda calculus calculator. See the sources and syntax info in the <a href="https://github.com/WhiteBlackGoose/LambdaCalculusFSharp"><b>GitHub repository</b></a>.
</p>


<div class="segment">
<h3>Parsing</h3>
<p>
    Returns internal F# representation of the expression
</p>
<input class="neat input-box" @bind:get="TextParse" @bind:set="async v => { TextParse = v; await UpdateUrl(); }" style="width: 50%" @onkeypress="args => { if (args.Key[0] is 'E' /*enter*/ ) Parse(); }" />
<button class="neat submit-button" @onclick="Parse">Parse</button>
<p class="result">
    <pre>@ResultParse</pre>
</p>
</div>

<br><br><br>


<div class="segment">
<h3>α equivalence</h3>
<p>
    Shows whether two expressions are equivalent up to lambdas' parameter names.
</p>
<input class="neat input-box" @bind:get="TextAlphaEquivalence1" @bind:set="async v => { TextAlphaEquivalence1 = v; await UpdateUrl(); }" style="width: 35%" @onkeypress="args => { if (args.Key[0] is 'E' /*enter*/ ) AlphaEquivalence(); }" />
<input class="neat input-box" @bind:get="TextAlphaEquivalence2" @bind:set="async v => { TextAlphaEquivalence2 = v; await UpdateUrl(); }" style="width: 35%" @onkeypress="args => { if (args.Key[0] is 'E' /*enter*/ ) AlphaEquivalence(); }" />
<button class="neat submit-button" @onclick="AlphaEquivalence">α equivalence</button>
<p class="result">
    @ResultAlphaEquivalence
</p>
</div>

<br><br><br>


<div class="segment">
<h3>Substitution</h3>
<p>
    Performs a substitution of free variables.
</p>
<input class="neat input-box" @bind:get="TextSubstitution1" @bind:set="async v => { TextSubstitution1 = v; await UpdateUrl(); }" style="width: 30%" />
<input class="neat input-box" @bind:get="TextSubstitution2" @bind:set="async v => { TextSubstitution2 = v; await UpdateUrl(); }" style="width: 10%" />
<input class="neat input-box" @bind:get="TextSubstitution3" @bind:set="async v => { TextSubstitution3 = v; await UpdateUrl(); }" style="width: 30%" />
<button class="neat submit-button" @onclick="Substitute">Substitute</button>
<p class="expr result">
    @ResultSubstitution
</p>
</div>

<br><br><br>


<div class="segment">
<h3>β-reduction</h3>
<p>
    Tries to β-reduce an expression until the reduction becomes cyclic.
</p>
<input class="neat input-box" @bind:get="TextBetaReduce" @bind:set="async v => { TextBetaReduce = v; await UpdateUrl(); }" style="width: 50%" @onkeypress="args => { if (args.Key[0] is 'E' /*enter*/ ) BetaReduce(); }" />
<button class="neat submit-button" @onclick="BetaReduce">β reduction</button>
<p class="expr result">
    @ResultBetaReduce
</p>
</div>

<br><br><br>

<div class="segment">
<h3>η-reduction</h3>
<p>
    η-reduces the given expression (by replacing redundant abstractions: \x.ex -> e).
</p>
<input class="neat input-box" @bind:get="TextEtaReduce" @bind:set="async v => { TextEtaReduce = v; await UpdateUrl(); }" style="width: 50%" @onkeypress="args => { if (args.Key[0] is 'E' /*enter*/ ) EtaReduce(); }" />
<button class="neat submit-button" @onclick="EtaReduce">η reduction</button>
<p class="expr result">
    @ResultEtaReduce
</p>
</div>

<br><br><br>

<div class="segment">
<h3>βη-reduction</h3>
<p>
    Performs βη-reduction.
</p>
<input class="neat input-box" @bind:get="TextBetaEtaReduce" @bind:set="async v => { TextBetaEtaReduce = v; await UpdateUrl(); }" style="width: 50%" @onkeypress="args => { if (args.Key[0] is 'E' /*enter*/ ) BetaEtaReduce(); }" />
<button class="neat submit-button" @onclick="BetaEtaReduce">βη reduction</button>
<p class="expr result">
    @ResultBetaEtaReduce
</p>
</div>

<br><br><br>


<div class="segment">
<h3>Transpile to C#</h3>
<p>
    That's a fun section. Transpiles lambda calculus expression into C# with lambdas and dynamic.
</p>
<input class="neat input-box" @bind:get="TextToCSharp" @bind:set="async v => { TextToCSharp = v; await UpdateUrl(); }" style="width: 50%" @onkeypress="args => { if (args.Key[0] is 'E' /*enter*/ ) ToCSharp(); }" />
<button class="neat submit-button" @onclick="ToCSharp">Transpile to C#</button>
<p class="expr result">
    @ResultToCSharp
</p>
</div>

<br><br><br><br><br><br>
<br><br><br><br><br><br>
<br><br><br><br><br><br>

<div class="qr-section">
    <h3>Share your calculations!</h3>
    <p>Scan the QR code below to share these inputs with others:</p>
    <div class="qr-code">
        <img src="@QrCodeImage" alt="QR Code" />
    </div>
</div>


@using LambdaCalculus

@code {
    private static readonly Dictionary<string, string> Defaults = new()
    {
        ["parsing"] = @"(\x.xx)y",
        ["alpha1"] = @"\x.xx",
        ["alpha2"] = @"\y.yy",
        ["betaReduce"] = @"(\x.xx)(\y.y)z",
        ["etaReduce"] = @"\yx.ex",
        ["betaEtaReduce"] = @"(\yx.yx)x",
        ["substitute1"] = "xxx",
        ["substitute2"] = "x",
        ["substitute3"] = "y",
        ["toCSharp"] = @"(\x.xx)(\y.yy)"
    };

    public string TextParse { get; set; } = Defaults["parsing"];
    public string ResultParse = "";
    public void Parse()
    {
        var parsed = Parsing.parse(TextParse);
        if (parsed.IsOk)
            ResultParse = $"{Output.sprintLambda(parsed.ResultValue)}\n\n{parsed.ResultValue}";
        else
            ResultParse = $"Error: {parsed.ErrorValue}";
    }

    public string TextAlphaEquivalence1 { get; set; } = Defaults["alpha1"];
    public string TextAlphaEquivalence2 { get; set; } = Defaults["alpha2"];
    public string ResultAlphaEquivalence = "";
    public void AlphaEquivalence()
    {
        var parsed1 = Parsing.parse(TextAlphaEquivalence1);
        var parsed2 = Parsing.parse(TextAlphaEquivalence2);
        if (parsed1.IsOk && parsed2.IsOk)
            ResultAlphaEquivalence = Atoms.alphaEqual(parsed1.ResultValue, parsed2.ResultValue) ? "They're α-equivalent" : "They're not α-equivalent";
        else if (parsed1.IsError)
            ResultAlphaEquivalence = $"Error: {parsed1.ErrorValue}";
        else
            ResultAlphaEquivalence = $"Error: {parsed2.ErrorValue}";
    }

    public string TextBetaReduce { get; set; } = Defaults["betaReduce"];
    public string ResultBetaReduce = "";
    public void BetaReduce()
    {
        var parsed = Parsing.parse(TextBetaReduce);
        if (parsed.IsOk)
        {
            var reduced = Atoms.betaReduce(parsed.ResultValue);
            if (reduced is Atoms.ReductionResult.MayTerminate mt)
                ResultBetaReduce = Output.sprintLambda(mt.Item);
            else
                ResultBetaReduce = "Cannot β-reduce: never terminates.";
        }
        else
            ResultBetaReduce = $"Error: {parsed.ErrorValue}";
    }

    public string TextEtaReduce { get; set; } = Defaults["etaReduce"];
    public string ResultEtaReduce = "";
    public void EtaReduce()
    {
        var parsed = Parsing.parse(TextEtaReduce);
        if (parsed.IsOk)
            ResultEtaReduce = Output.sprintLambda(Atoms.etaReduce(parsed.ResultValue));
        else
            ResultEtaReduce = $"Error: {parsed.ErrorValue}";
    }

    public string TextBetaEtaReduce { get; set; } = Defaults["betaEtaReduce"];
    public string ResultBetaEtaReduce = "";
    public void BetaEtaReduce()
    {
        var parsed = Parsing.parse(TextBetaEtaReduce);
        if (parsed.IsOk)
        {
            var reduced = Atoms.betaEtaReduce(parsed.ResultValue);
            if (reduced is Atoms.ReductionResult.MayTerminate mt)
                ResultBetaEtaReduce = Output.sprintLambda(mt.Item);
            else
                ResultBetaEtaReduce = "Cannot βη-reduce: never terminates.";
        }
        else
            ResultBetaEtaReduce = $"Error: {parsed.ErrorValue}";
    }

    public string TextSubstitution1 { get; set; } = Defaults["substitute1"];
    public string TextSubstitution2 { get; set; } = Defaults["substitute2"];
    public string TextSubstitution3 { get; set; } = Defaults["substitute3"];
    public string ResultSubstitution = "";
    public void Substitute()
    {
        if (TextSubstitution2.Length is not 1)
            ResultSubstitution = "Error: The second field should be a single-char variable.";
        else
        {
            var x = TextSubstitution2[0];
            var parsed1 = Parsing.parse(TextSubstitution1);
            var parsed2 = Parsing.parse(TextSubstitution3);
            if (parsed1.IsOk && parsed2.IsOk)
                ResultSubstitution = Output.sprintLambda(Atoms.substitute(x, parsed2.ResultValue, parsed1.ResultValue));
            else if (parsed1.IsError)
                ResultSubstitution = $"Error: {parsed1.ErrorValue}";
            else
                ResultSubstitution = $"Error: {parsed2.ErrorValue}";
        }
    }

    public string TextToCSharp { get; set; } = Defaults["toCSharp"];
    public string ResultToCSharp = "";
    public void ToCSharp()
    {
        var parsed = Parsing.parse(TextToCSharp);
        if (parsed.IsOk)
            ResultToCSharp = LambdaCalculus.ToCSharp.toCSharp(parsed.ResultValue);
        else
            ResultToCSharp = $"Error: {parsed.ErrorValue}";
    }

    private string QrCodeImage = "";

    private Dictionary<string, string> GetCurrentInputs() => new()
    {
        ["parsing"] = TextParse,
        ["alpha1"] = TextAlphaEquivalence1,
        ["alpha2"] = TextAlphaEquivalence2,
        ["betaReduce"] = TextBetaReduce,
        ["etaReduce"] = TextEtaReduce,
        ["betaEtaReduce"] = TextBetaEtaReduce,
        ["substitute1"] = TextSubstitution1,
        ["substitute2"] = TextSubstitution2,
        ["substitute3"] = TextSubstitution3,
        ["toCSharp"] = TextToCSharp
    };

    private bool HasNonDefaultInputs()
    {
        var inputs = GetCurrentInputs();
        return inputs.Any(kvp => Defaults.TryGetValue(kvp.Key, out var def) && kvp.Value != def);
    }

    private Dictionary<string, string> GetNonDefaultInputs()
    {
        var inputs = GetCurrentInputs();
        return inputs.Where(kvp => Defaults.TryGetValue(kvp.Key, out var def) && kvp.Value != def)
                     .ToDictionary(kvp => kvp.Key, kvp => kvp.Value);
    }

    private async Task UpdateUrl()
    {
        var nonDefault = GetNonDefaultInputs();
        string newUrl;
        if (nonDefault.Count > 0)
        {
            var json = JsonSerializer.Serialize(nonDefault);
            var base64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(json));
            var encoded = Uri.EscapeDataString(base64);
            newUrl = $"?d={encoded}";
        }
        else
        {
            newUrl = "/";
        }
        
        await JS.InvokeVoidAsync("eval", $"window.history.pushState(null, '', '{newUrl}')");
        GenerateQrCode();
    }

    private void LoadFromUrl()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        
        if (query.TryGetValue("d", out var encoded) && !string.IsNullOrEmpty(encoded))
        {
            try
            {
                var base64 = Uri.UnescapeDataString(encoded);
                var json = System.Text.Encoding.UTF8.GetString(Convert.FromBase64String(base64));
                var inputs = JsonSerializer.Deserialize<Dictionary<string, string>>(json);
                
                if (inputs != null)
                {
                    if (inputs.TryGetValue("parsing", out var parsing)) TextParse = parsing;
                    if (inputs.TryGetValue("alpha1", out var alpha1)) TextAlphaEquivalence1 = alpha1;
                    if (inputs.TryGetValue("alpha2", out var alpha2)) TextAlphaEquivalence2 = alpha2;
                    if (inputs.TryGetValue("betaReduce", out var betaReduce)) TextBetaReduce = betaReduce;
                    if (inputs.TryGetValue("etaReduce", out var etaReduce)) TextEtaReduce = etaReduce;
                    if (inputs.TryGetValue("betaEtaReduce", out var betaEtaReduce)) TextBetaEtaReduce = betaEtaReduce;
                    if (inputs.TryGetValue("substitute1", out var substitute1)) TextSubstitution1 = substitute1;
                    if (inputs.TryGetValue("substitute2", out var substitute2)) TextSubstitution2 = substitute2;
                    if (inputs.TryGetValue("substitute3", out var substitute3)) TextSubstitution3 = substitute3;
                    if (inputs.TryGetValue("toCSharp", out var toCSharp)) TextToCSharp = toCSharp;
                }
            }
            catch
            {
            }
        }
    }

    private void GenerateQrCode()
    {
        try
        {
            var url = Nav.Uri;
            using var qrGenerator = new QRCoder.QRCodeGenerator();
            using var qrCodeData = qrGenerator.CreateQrCode(url, QRCoder.QRCodeGenerator.ECCLevel.Q);
            using var qrCode = new QRCoder.PngByteQRCode(qrCodeData);
            var bytes = qrCode.GetGraphic(20);
            QrCodeImage = $"data:image/png;base64,{Convert.ToBase64String(bytes)}";
        }
        catch
        {
            QrCodeImage = "";
        }
    }

    protected override void OnInitialized()
    {
        LoadFromUrl();
        GenerateQrCode();
    }
}
